# Copy to eval/tensorzero/.env (git-ignored) and fill in the real value.
# LM Studio API key (the gateway uses it to call the Qwen model on the host).
LMSTUDIO_API_KEY=sk-lm-xxxxxxxx

# OpenRouter API key (gateway uses it for the `coding` function -> qwen3.6-35b-a3b).
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
