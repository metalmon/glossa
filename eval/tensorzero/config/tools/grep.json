{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "file_type": {
      "default": null,
      "description": "only this file type, e.g. pdf (-t)",
      "type": [
        "string",
        "null"
      ]
    },
    "fixed": {
      "default": null,
      "description": "treat the pattern as a fixed string, not a regex (-F)",
      "type": [
        "boolean",
        "null"
      ]
    },
    "glob": {
      "default": null,
      "description": "only files whose path matches this ripgrep -g glob, e.g. *.pdf, **/*",
      "type": [
        "string",
        "null"
      ]
    },
    "ignore_case": {
      "default": null,
      "description": "case-insensitive matching (-i)",
      "type": [
        "boolean",
        "null"
      ]
    },
    "pattern": {
      "description": "ripgrep-style regex pattern (literal text also works)",
      "type": "string"
    },
    "word": {
      "default": null,
      "description": "match whole words only (-w)",
      "type": [
        "boolean",
        "null"
      ]
    }
  },
  "required": [
    "pattern"
  ],
  "type": "object"
}
