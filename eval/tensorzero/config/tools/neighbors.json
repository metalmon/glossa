{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "depth": {
      "default": null,
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "n": {
      "description": "chunk number, exactly as shown in `[#n]` in a search result",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "path": {
      "description": "document path, exactly as shown in a search result",
      "type": "string"
    }
  },
  "required": [
    "path",
    "n"
  ],
  "type": "object"
}
