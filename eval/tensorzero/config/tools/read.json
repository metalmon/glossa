{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "include_images": {
      "default": null,
      "description": "include embedded images (default true)",
      "type": [
        "boolean",
        "null"
      ]
    },
    "n": {
      "description": "chunk number to read, exactly as shown in `[#n]` in a search result (page number for PDFs)",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "path": {
      "description": "document path, exactly as shown in a search result",
      "type": "string"
    }
  },
  "required": [
    "path",
    "n"
  ],
  "type": "object"
}
