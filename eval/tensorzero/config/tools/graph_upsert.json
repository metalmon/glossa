{
  "$defs": {
    "UpsertEdge": {
      "description": "A directed edge identified by node labels (or section refs) at both endpoints.",
      "properties": {
        "edge_type": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      },
      "required": [
        "from",
        "edge_type",
        "to",
        "source_path"
      ],
      "type": "object"
    },
    "UpsertNode": {
      "description": "A reasoning node to create/update, identified by label only (no id).\nThe system derives the canonical id from `node_type` + `label` and deduplicates by label.",
      "properties": {
        "aliases": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "label": {
          "type": "string"
        },
        "node_type": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        }
      },
      "required": [
        "node_type",
        "label",
        "source_path"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "edges": {
      "default": [],
      "items": {
        "$ref": "#/$defs/UpsertEdge"
      },
      "type": "array"
    },
    "nodes": {
      "default": [],
      "items": {
        "$ref": "#/$defs/UpsertNode"
      },
      "type": "array"
    }
  },
  "type": "object"
}
